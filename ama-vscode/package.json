
{
  "name": "ama-vscode",
  "displayName": "AMA",
  "description": "AI Messenger Agent for Maneki-AI",
  "version": "0.3.0",
  "publisher": "winsentrobot008",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/winsentrobot008/AMA.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "github",
    "issue",
    "task",
    "messenger",
    "agent",
    "ama",
    "cline",
    "mcp",
    "llm",
    "deepseek"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ama.start",
    "onCommand:ama.generateTaskChain",
    "onCommand:ama.executeTaskChain",
    "onView:amaTasksView",
    "onView:amaLogsView",
    "onView:amaTaskChainView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ama",
          "title": "AMA",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ama": [
        {
          "type": "tree",
          "id": "amaTasksView",
          "name": "任务列表"
        },
        {
          "type": "webview",
          "id": "amaLogsView",
          "name": "日志"
        },
        {
          "type": "webview",
          "id": "amaTaskChainView",
          "name": "任务链"
        }
      ]
    },
    "commands": [
      {
        "command": "ama.connectToCline",
        "title": "Connect to CLINE (GitHub)",
        "icon": "$(plug)"
      },
      {
        "command": "ama.connectToClineMCP",
        "title": "Connect to CLINE MCP",
        "icon": "$(plug)"
      },
      {
        "command": "ama.disconnectFromClineMCP",
        "title": "Disconnect from CLINE MCP",
        "icon": "$(plug)"
      },
      {
        "command": "ama.start",
        "title": "AMA: 启动轮询"
      },
      {
        "command": "ama.stop",
        "title": "AMA: 停止轮询"
      },
      {
        "command": "ama.refresh",
        "title": "AMA: 刷新任务列表",
        "icon": "$(refresh)"
      },
      {
        "command": "ama.openLog",
        "title": "AMA: 打开日志面板"
      },
      {
        "command": "ama.openTaskFile",
        "title": "AMA: 打开任务文件"
      },
      {
        "command": "ama.runTask",
        "title": "AMA: 执行任务"
      },
      {
        "command": "ama.clearLogs",
        "title": "AMA: 清空日志"
      },
      {
        "command": "ama.askDeepSeek",
        "title": "AMA: 询问 DeepSeek",
        "icon": "$(hubot)"
      },
      {
        "command": "ama.generateTaskChain",
        "title": "AMA: 生成任务链 (LLM)",
        "icon": "$(list-tree)"
      },
      {
        "command": "ama.executeTaskChain",
        "title": "AMA: 执行任务链",
        "icon": "$(play)"
      },
      {
        "command": "ama.abortTaskChain",
        "title": "AMA: 中止任务链",
        "icon": "$(debug-stop)"
      },
      {
        "command": "ama.autoOrchestrate",
        "title": "AMA: 自动调度 (LLM)",
        "icon": "$(rocket)"
      },
      {
        "command": "ama.openTaskChainInput",
        "title": "AMA: 打开任务链输入面板",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ama.connectToCline",
          "when": "view == amaTasksView",
          "group": "navigation@1"
        },
        {
          "command": "ama.connectToClineMCP",
          "when": "view == amaTasksView",
          "group": "navigation@2"
        },
        {
          "command": "ama.start",
          "when": "view == amaTasksView",
          "group": "navigation@3"
        },
        {
          "command": "ama.stop",
          "when": "view == amaTasksView",
          "group": "navigation@4"
        },
        {
          "command": "ama.askDeepSeek",
          "when": "view == amaTasksView",
          "group": "navigation@5"
        },
        {
          "command": "ama.generateTaskChain",
          "when": "view == amaTasksView",
          "group": "navigation@6"
        },
        {
          "command": "ama.executeTaskChain",
          "when": "view == amaTasksView",
          "group": "navigation@7"
        },
        {
          "command": "ama.autoOrchestrate",
          "when": "view == amaTasksView",
          "group": "navigation@8"
        },
        {
          "command": "ama.refresh",
          "when": "view == amaTasksView",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "ama.openTaskFile",
          "when": "view == amaTasksView && viewItem != null",
          "group": "inline"
        },
        {
          "command": "ama.runTask",
          "when": "view == amaTasksView && viewItem != null",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "AMA",
      "properties": {
        "ama.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token（需要 repo 权限）",
          "scope": "application"
        },
        "ama.repo": {
          "type": "string",
          "default": "winsentrobot008/DevDirector-Tasks",
          "description": "要监听的 GitHub 仓库，格式：owner/repo",
          "scope": "application"
        },
        "ama.label": {
          "type": "string",
          "default": "cline",
          "description": "要监听的 Issue 标签",
          "scope": "application"
        },
        "ama.pollIntervalSeconds": {
          "type": "number",
          "default": 20,
          "minimum": 5,
          "description": "轮询间隔（秒）",
          "scope": "application"
        },
        "ama.tasksDir": {
          "type": "string",
          "default": "tasks",
          "description": "任务文件存放目录（相对于工作区根目录）",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npx ts-node src/test/runTest.ts",
    "test:watch": "npx ts-node --watch src/test/runTest.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
